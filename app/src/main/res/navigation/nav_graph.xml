<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <!-- ═══════════════════════════════════════════════════════
         ONBOARDING + AUTH FLOW
    ═══════════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.vidyavahini.app.ui.onboarding.OnboardingFragment"
        android:label="Welcome">
        <action
            android:id="@+id/action_onboarding_to_signIn"
            app:destination="@id/signInFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />
    </fragment>

    <fragment
        android:id="@+id/signInFragment"
        android:name="com.vidyavahini.app.ui.auth.SignInFragment"
        android:label="Sign In">
        <action
            android:id="@+id/action_signIn_to_signUp"
            app:destination="@id/signUpFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_signIn_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.vidyavahini.app.ui.auth.SignUpFragment"
        android:label="Sign Up">
        <action
            android:id="@+id/action_signUp_to_profileSetup"
            app:destination="@id/profileSetupFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/profileSetupFragment"
        android:name="com.vidyavahini.app.ui.setup.ProfileSetupFragment"
        android:label="Complete Profile">
        <action
            android:id="@+id/action_profileSetup_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <!-- ═══════════════════════════════════════════════════════
         BOTTOM NAVIGATION TABS (4 main screens)
    ═══════════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.vidyavahini.app.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_safe_reach"
            app:destination="@id/safeReachFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />
    </fragment>

    <fragment
        android:id="@+id/trackingFragment"
        android:name="com.vidyavahini.app.ui.tracking.TrackingFragment"
        android:label="Live Map" />

    <fragment
        android:id="@+id/reportIssueFragment"
        android:name="com.vidyavahini.app.ui.issues.ReportIssueFragment"
        android:label="Report Issue" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.vidyavahini.app.ui.profile.ProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profile_to_onboarding"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <!-- ═══════════════════════════════════════════════════════
         SECONDARY SCREENS
    ═══════════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/safeReachFragment"
        android:name="com.vidyavahini.app.ui.safereach.SafeReachFragment"
        android:label="Safe Reach">
        <action
            android:id="@+id/action_safeReach_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Legacy phone-auth fragments (kept for backward compatibility) -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.vidyavahini.app.ui.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_otp"
            app:destination="@id/otpFragment" />
    </fragment>

    <fragment
        android:id="@+id/otpFragment"
        android:name="com.vidyavahini.app.ui.auth.OtpFragment"
        android:label="Verify OTP">
        <action
            android:id="@+id/action_otp_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_otp_to_register"
            app:destination="@id/registerFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.vidyavahini.app.ui.auth.RegisterFragment"
        android:label="Complete Profile">
        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>
