<?xml version="1.0" encoding="utf-8"?>
<!-- Registration Screen — profile setup with dropdowns -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Complete Your Profile"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="Tell us your name, route, and boarding stop"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"/>

        <!-- ── Name ───────────────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            style="@style/VidyaTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/register_name_hint"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:textColor="@color/text_primary"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Route dropdown ─────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRoute"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/register_route_hint"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/primary_orange"
            app:hintTextColor="@color/primary_orange"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <AutoCompleteTextView
                android:id="@+id/dropdownRoute"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Boarding stop dropdown ──────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilStop"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/register_stop_hint"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/primary_orange"
            app:hintTextColor="@color/primary_orange"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <AutoCompleteTextView
                android:id="@+id/dropdownStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:enabled="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Parent phone (optional) ────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilParentPhone"
            style="@style/VidyaTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/register_parent_phone_hint"
            android:layout_marginBottom="32dp"
            app:prefixText="+91  "
            app:prefixTextColor="@color/primary_orange">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etParentPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:maxLength="10"
                android:textColor="@color/text_primary"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Loading indicator ──────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:indeterminate="true"
            android:indeterminateTint="@color/primary_orange"/>

        <!-- ── Register button ────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            style="@style/VidyaButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_register"/>

    </LinearLayout>
</ScrollView>
