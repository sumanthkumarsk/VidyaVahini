<?xml version="1.0" encoding="utf-8"?>
<!-- Report Issue Fragment -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Report Bus Issue"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="Alert all students on your route immediately"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- ── Active Alert Banner (shown if alert exists) ──────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardActiveAlert"
            style="@style/VidyaCard.Breakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ ACTIVE ALERT"
                    android:textColor="#FF5252"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvActiveAlert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearAlert"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Clear Alert"
                    android:textColor="#FF5252"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Issue Type Selection ───────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            style="@style/VidyaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SELECT ISSUE TYPE"
                    android:textColor="@color/primary_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <!-- 2x2 Grid of issue buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBreakdown"
                        style="@style/VidyaButton.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:alpha="0.7"
                        android:text="🔧 Breakdown"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDelay"
                        style="@style/VidyaButton.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:alpha="0.7"
                        android:text="⏰ Heavy Delay"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDiverted"
                        style="@style/VidyaButton.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:alpha="0.7"
                        android:text="🔄 Diverted"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancelled"
                        style="@style/VidyaButton.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:alpha="0.7"
                        android:text="❌ Cancelled"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Optional Note ─────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            style="@style/VidyaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADDITIONAL NOTE (OPTIONAL)"
                    android:textColor="@color/primary_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/VidyaTextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="E.g. Near Silk Board flyover">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCustomNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:lines="2"
                        android:maxLines="3" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Submit Button ──────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitIssue"
            style="@style/VidyaButton.Secondary"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:text="⚠️ Report Issue to All Students"
            android:textSize="15sp" />

        <!-- ── Success Card (hidden until reported) ───────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSuccess"
            app:cardBackgroundColor="#E8F5E9"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:id="@+id/ivSuccessIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="48sp" />

                <TextView
                    android:id="@+id/tvSuccessMsg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:textColor="@color/success"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
