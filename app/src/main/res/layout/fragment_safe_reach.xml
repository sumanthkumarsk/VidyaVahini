<?xml version="1.0" encoding="utf-8"?>
<!-- Safe Reach Screen - tap to notify parents of safe arrival -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        android:paddingTop="48dp">

        <!-- Back button / Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Safe Reach"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Illustration -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏫"
            android:textSize="80sp"
            android:layout_gravity="center" />

        <!-- Student name -->
        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Student"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="Tap the button below to let your parents know you've safely reached college"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <!-- Main action button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReached"
            style="@style/VidyaButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/success"
            android:text="✅  I Reached College Safely"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Notification info -->
        <TextView
            android:id="@+id/tvNotifInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="📱 Sends push notification to parent's phone\n📟 SMS fallback for feature phones"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Success checkmark (shown after tap) -->
        <ImageView
            android:id="@+id/ivCheckmark"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone"
            android:contentDescription="Success checkmark" />

        <!-- Success status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="@color/success"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
